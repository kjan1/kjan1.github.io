  <linkShapes>
    <shape name="default" curviness="0.0">
      <lines>
        <line x="-0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
        <line x="0.0" visible="true">
          <dash value="1.0"></dash>
          <dash value="0.0"></dash>
        </line>
        <line x="0.2" visible="false">
          <dash value="0.0"></dash>
          <dash value="1.0"></dash>
        </line>
      </lines>
      <indicator>
        <shape name="link direction" rotatable="true" editableColorIndex="0">
          <line endX="90" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
          <line endX="210" startY="150" marked="true" color="-1920102913" endY="180" startX="150"></line>
        </shape>
      </indicator>
    </shape>
  </linkShapes>
  <previewCommands>setup repeat 75 [ go ]</previewCommands>
  <experiments>
    <experiment name="experiment v1" repetitions="3" sequentialRunOrder="true" runMetricsEveryStep="false" timeLimit="260">
      <setup>setup</setup>
      <go>go</go>
      <runMetricsCondition>ticks mod 60 = 0</runMetricsCondition>
      <metrics>
        <metric>mean-pol-belief</metric>
        <metric>mean-rel-belief</metric>
        <metric>var-pol-belief</metric>
        <metric>var-rel-belief</metric>
        <metric>mean-belonging</metric>
        <metric>attendance-rate</metric>
        <metric>num-disengaged</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="num_members">
          <value value="150"></value>
          <value value="300"></value>
        </enumeratedValueSet>
        <steppedValueSet variable="polarization-degree" first="0.05" step="0.2" last="1"></steppedValueSet>
        <enumeratedValueSet variable="ext-r">
          <value value="-0.4"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="lambda-r">
          <value value="0.01"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="ext-p">
          <value value="-0.4"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="lambda-p">
          <value value="0.01"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="delta">
          <value value="0.2"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="epsilon-r">
          <value value="0.6"></value>
        </enumeratedValueSet>
        <steppedValueSet variable="epsilon-p" first="0.1" step="0.9" last="2"></steppedValueSet>
        <enumeratedValueSet variable="phi">
          <value value="0.05"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="theta-min">
          <value value="0.06"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="alpha">
          <value value="0.1"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="p-weight">
          <value value="0.4"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="rho">
          <value value="0.05"></value>
        </enumeratedValueSet>
        <steppedValueSet variable="mu-p" first="0.05" step="0.08" last="0.5"></steppedValueSet>
        <enumeratedValueSet variable="beta">
          <value value="0.3"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="mu-r">
          <value value="0.35"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="gamma">
          <value value="0.6"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
  </experiments>
</model>
