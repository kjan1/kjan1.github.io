<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.0" snapToGrid="true">
  <code><![CDATA[;; Political Polarization in Church Communities - Agent-Based Model
; One tick = one Sunday service

extensions [nw]

globals [
  mean-pol-belief
  mean-rel-belief
  mean-combined-belief
  var-pol-belief
  var-rel-belief
  mean-belonging
  attendance-rate
  num-disengaged
]

;; Rename agents to church "members" -> agents are now referred to as members in code
breed [members member]

;; Rename the relationships (links) between members to "connections"
undirected-link-breed [ connections connection ]

;; Each agent has: 
members-own [
  Religious-Belief
  Political-Belief
  Combined-Belief
  Belonging 
  Behavior ; attendance
  Seat-x ; church seat position x
  Seat-y ; church seat position y
  Attended? ; boolean
  Disengaged?
  delta-p ; political delta/change for tick
  delta-r ; religious delta/change for tick
]

; Each tie has:
connections-own [
  Strength
  ;Demographics
  ;Sundays_Spent_Together ; repeated interactions = more strength growth
  Duration
  ;Last_Seen ; in weeks
]

patches-own [
  is-seat?
]

;;; ============================================================
;;;                          SET UP
;;; ============================================================

to setup
  clear-all
  setup-world
  
  create-network
  
  setup-members
  
  initialize-characteristics
  
  update-church-stats
  
  reset-ticks
end


to setup-world
  let stage 2
  let aisle 2
  let min-width 5
  let min-length 10
  let seat-columns-per-side max list 2 ceiling (sqrt num_members / 3)
  let seats-per-row (2 * seat-columns-per-side)
  let rows ceiling (num_members / seats-per-row)
  let church_width max list ((2 * seat-columns-per-side) + aisle + 2) min-width
  let church_length max list (rows + stage + 1) min-length
  
  resize-world (- church_width / 2) (church_width / 2) (- church_length / 2) (church_length / 2) 
  set-patch-size 600 / (max-pycor - min-pycor + 1) 
  
  ask patches [ ; general color
    set pcolor [204 186 120]
  ]
  ask patches with [abs(pxcor) <= aisle / 2] [ ; aisle
    set pcolor [214 211 198]
  ]
  ask patches with [pycor > (church_length / 2 - stage)] [ ; stage
    set pcolor white
  ]
  ask patches [
    set is-seat? false
  ]
  ask patches with [abs(pxcor) > aisle / 2 and pycor < max-pycor - stage] [ ; dont have people sit in the aisle or stage
    set is-seat? true
  ]
end

to setup-members
  ask members [
    set shape "person"
    move-to one-of patches with [is-seat? and not any? turtles-here]
    set Seat-x pxcor
    set Seat-y pycor
  ]
end


to initialize-characteristics
  ask members [
    set Political-Belief max list -1 (min list 1 (random-normal 0 polarization-degree)) ; set political belief between -1 and 1 following a normal distribution
    set Religious-Belief max list -1 (min list 1 (random-normal 0 polarization-degree))
    set Combined-Belief calc-combined Political-Belief Religious-Belief
    set Belonging (0.5 + random-float 0.5) ; uniform between [0.5, 1]
    set Behavior (0.6 + random-float 0.4) ; uniform between [0.6, 1]
    set Attended? false
    set Disengaged? false
    set delta-p 0
    set delta-r 0
  ]
end



;;; ============================================================
;;;                     SET UP NETWORK
;;; ============================================================

to create-network
  create-initial-connections
  initialize-tie-characteristics
end

to create-initial-connections ; and agents
  clear-links
  ask links [ die ]
  nw:generate-watts-strogatz members connections num_members 2 0.1 ; generate a Watts–Strogatz small-world network. Gives about 4 connections per agent
  ask links [
    set color gray
  ]
end

to initialize-tie-characteristics
  ask links [
    set Strength 1
    set Duration 0 ; nothing uses this right now
  ]
end


;;; ============================================================
;;;                     RUNNING SIMULATION
;;; ============================================================
to go
  ask members with [not Disengaged?] [
  compute-attendance
  compute-belief
  update-belief
  update-belonging
  update-behavior
  ]
  update-church-stats
  tick
end

;;; ============================================================
;;;                         BELIEF
;;; ============================================================

to compute-belief  
  set delta-p 0
  set delta-r 0
  
  ifelse attended? [
    ;; Political filtered neighbors: |b^p_j - b^p_i| < epsilon-p
    let pol-neighbors connection-neighbors with [ abs (Political-Belief - [Political-Belief] of myself) < epsilon-p ]
    if any? pol-neighbors [ ; only change if there is at least one similar-enough neighbor
      let total-w sum [ [Strength] of connection-with myself ] of pol-neighbors
      if total-w > 0 [
        set delta-p mu-p * sum [ ; set change in political belief equal to political susceptibility * sum...
          ([Strength] of connection-with myself / total-w) * belonging * (Political-Belief - [Political-Belief] of myself) ; similar belief weight * belonging * belief gap
        ] of pol-neighbors
      ]
    ]
    
    ;; Religious filtered neighbors: |b^r_j - b^r_i| < epsilon-r
    let rel-neighbors connection-neighbors with [ abs (Religious-Belief - [Religious-Belief] of myself) < epsilon-r ]
    if any? rel-neighbors [
      let total-w sum [ [Strength] of connection-with myself ] of rel-neighbors
      if total-w > 0 [
        set delta-r mu-r * sum [
          ([Strength] of connection-with myself / total-w) * belonging * (Religious-Belief - [Religious-Belief] of myself)
        ] of rel-neighbors
      ]
    ]
  ]
  []
  ;; External signal (always applied, regardless of attendance)
  set delta-p delta-p + lambda-p * (ext-p - Political-Belief)
  set delta-r delta-r + lambda-r * (ext-r - Religious-Belief)
end

to update-belief
  set Political-Belief median (list -1 (Political-Belief + delta-p) 1)
  set Religious-Belief median (list -1 (Religious-Belief + delta-r) 1)
  set Combined-Belief calc-combined Political-Belief Religious-Belief ; calc-combined is a helper function to calculated weighted combined score
end


;;; ============================================================
;;;                        BELONGING
;;; ============================================================

to update-belonging
  ifelse attended? [
    let divergence abs (Combined-Belief - mean-neighbor-combined) ; mean-neighbor-combined is a helper function
    ;; Delta-B^belief = alpha*(1 - divergence) - beta*divergence
    let delta-belief (alpha * (1 - divergence)) - (beta * divergence)
    ;; Delta-B^att = phi (attendance bonus)
    set belonging median (list theta-min (belonging + delta-belief + phi) 1)
  ] [
    ;; Delta-B^decay = -rho * (1 - B_i)
    set belonging median (list theta-min (belonging + (- rho * (1 - belonging))) 1)
  ]
end

;;; ============================================================
;;;                   BEHAVIOR / ATTENDANCE
;;; ============================================================

to compute-attendance
  set Attended? (random-float 1 < Behavior)
  ifelse Attended? [set color green] [set color red]
end

to update-behavior
  let attending-neighbors connection-neighbors with [Attended?]
  let neighbor-combined-mean ifelse-value any? attending-neighbors
  [ mean [Combined-Belief] of attending-neighbors ]
  [ Combined-Belief ]
  let alignment (1 - abs (Combined-Belief - neighbor-combined-mean))
  set Behavior (gamma * Belonging) + ((1 - gamma) * alignment)
  set Behavior median (list 0 behavior 1)
  if Behavior < delta [
    remove-member
  ]
end

to remove-member
    set Disengaged? true
    ask my-connections [die]
    set color gray
    ask members with [not Disengaged?] [ set Attended? false ] 
end

;;; ============================================================
;;;                  CHURCH-LEVEL STATISTICS
;;; ============================================================

to update-church-stats
  let active members with [not Disengaged?]
  if not any? active [ stop ]
  set mean-pol-belief mean [ Political-Belief ] of turtles
  set mean-rel-belief mean [ Religious-Belief ] of turtles
  set mean-combined-belief mean [ Combined-Belief ] of turtles
  set var-pol-belief variance [ Political-Belief ] of turtles
  set var-rel-belief variance [ Religious-Belief ] of turtles
  set mean-belonging mean [ Belonging ] of turtles
  set attendance-rate count members with [ attended? ] / count turtles
  set num-disengaged count members with [ behavior < delta ]
end

;;; ============================================================
;;;                         HELPERS
;;; ============================================================

to-report calc-combined [ pol rel ]
  report median (list -1 ((p-weight * pol) + ((1 - p-weight) * rel)) 1)
end

to-report mean-neighbor-combined
  let nbrs link-neighbors
  ifelse any? nbrs
    [ report mean [ Combined-Belief ] of nbrs ]
    [ report Combined-Belief ]
end]]></code>
